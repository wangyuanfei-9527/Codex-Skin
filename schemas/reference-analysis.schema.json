{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex-skin-studio.local/schemas/reference-analysis.schema.json",
  "title": "Codex Skin Studio reference analysis",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "subject", "visual", "mustPreserve", "sourceRisks"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "subject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "identity", "summary", "signatureTraits"],
      "properties": {
        "kind": { "type": "string", "enum": ["fictional-character", "real-person", "object", "scene", "mixed"] },
        "identity": { "type": "string", "minLength": 1, "maxLength": 120 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 400 },
        "signatureTraits": {
          "type": "array",
          "minItems": 3,
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["palette", "composition", "lighting", "medium", "mood", "motifs"],
      "properties": {
        "palette": {
          "type": "array",
          "minItems": 4,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/color" }
        },
        "composition": { "type": "string", "minLength": 1, "maxLength": 300 },
        "lighting": { "type": "string", "minLength": 1, "maxLength": 220 },
        "medium": { "type": "string", "minLength": 1, "maxLength": 160 },
        "mood": { "type": "string", "minLength": 1, "maxLength": 220 },
        "motifs": {
          "type": "array",
          "minItems": 3,
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1, "maxLength": 80 }
        }
      }
    },
    "mustPreserve": {
      "type": "array",
      "minItems": 2,
      "maxItems": 10,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    },
    "sourceRisks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": { "type": "string", "minLength": 1, "maxLength": 120 }
    }
  },
  "$defs": {
    "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
  }
}
